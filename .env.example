# =============================================================================
# VoiceDesk — Environment Configuration
# Copy this file to .env and fill in the values below.
# =============================================================================

# ── OpenAI (LLM — required) ──────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Provider selection ────────────────────────────────────────────────────────
STT_PROVIDER=valsea
TTS_PROVIDER=valsea

# ── ElevenLabs (required when provider=elevenlabs) ───────────────────────────
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional — defaults to "George". Browse at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ── Valsea (required when provider=valsea) ────────────────────────────────────
# Get your key at https://valsea.ai
VALSEA_API_KEY=

# ── Supabase (database — required) ───────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# ── Company config ────────────────────────────────────────────────────────────
# Override the defaults set in app/config.py here if needed.
# COMPANY_NAME=Bright Smile Dental
# RECEPTIONIST_NAME=Sarah
# CUSTOM_INSTRUCTIONS=...

# ── Cal.com (optional — only needed for appointment booking) ─────────────────
# API key: Cal.com dashboard → Settings → Security → API Keys
CAL_COM_API_KEY=
# Event type ID: visible in the URL when you open an event type in Cal.com
CAL_COM_EVENT_TYPE_ID=
# IANA timezone — must match what Cal.com has for this event type
CAL_COM_TIMEZONE=Australia/Melbourne
